<?xml version="1.0" encoding="utf-8"?>
<!-- The 1920x1080 cluster, authored in px; StageLayout scales it to the screen.
     Structure mirrors web/index.html + the flex layout in style.css. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="1920px"
    android:layout_height="1080px"
    android:background="@color/navy">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="10px"
        android:orientation="vertical"
        android:background="@drawable/bd_frame"
        android:padding="16px">

        <!-- ================= TOP BAR ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="112px"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- DEVICE -->
            <LinearLayout
                android:id="@+id/device_panel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bd_line9"
                android:paddingHorizontal="22px"
                android:paddingVertical="16px">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="DEVICE:" android:textColor="@color/txt_label"
                    android:textSize="23px" android:textStyle="bold" android:letterSpacing="0.06" />
                <View android:id="@+id/device_led" android:layout_width="17px" android:layout_height="17px"
                    android:layout_marginStart="13px" android:background="@drawable/bd_led_green" />
                <TextView android:id="@+id/device_status" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="13px" android:text="CONNECTED"
                    android:textColor="@color/led_green" android:textSize="25px" android:textStyle="bold" />
            </LinearLayout>

            <!-- UPTIME -->
            <LinearLayout
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="20px" android:orientation="horizontal" android:gravity="center_vertical"
                android:background="@drawable/bd_line9" android:paddingHorizontal="22px" android:paddingVertical="16px">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="UPTIME:" android:textColor="@color/txt_label"
                    android:textSize="23px" android:textStyle="bold" android:letterSpacing="0.06" />
                <TextView android:id="@+id/uptime" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="12px" android:text="00:00:00" android:fontFamily="@font/dseg7_classic"
                    android:textColor="@color/seg_cyan" android:textSize="35px" />
            </LinearLayout>

            <!-- LOGO (flex 1) -->
            <ImageView
                android:layout_width="0px" android:layout_height="100px" android:layout_weight="1"
                android:layout_marginHorizontal="20px" android:src="@drawable/logo_w"
                android:scaleType="fitCenter" android:contentDescription="ECU TESTER — AL-AYED" />

            <!-- VOLTAGE -->
            <LinearLayout
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:background="@drawable/bd_line9" android:paddingHorizontal="22px" android:paddingVertical="16px">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="VOLTAGE:" android:textColor="@color/txt_label"
                    android:textSize="23px" android:textStyle="bold" android:letterSpacing="0.06" />
                <TextView android:id="@+id/voltage" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="12px" android:text="30.00" android:fontFamily="@font/dseg7_classic"
                    android:textColor="@color/seg_green" android:textSize="35px" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="12px" android:text="V" android:textColor="@color/txt_label"
                    android:textSize="23px" android:textStyle="bold" />
            </LinearLayout>

            <!-- CURRENT -->
            <LinearLayout
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="20px" android:orientation="horizontal" android:gravity="center_vertical"
                android:background="@drawable/bd_line9" android:paddingHorizontal="22px" android:paddingVertical="16px">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="CURRENT:" android:textColor="@color/txt_label"
                    android:textSize="23px" android:textStyle="bold" android:letterSpacing="0.06" />
                <TextView android:id="@+id/current" android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="12px" android:text="0.00" android:fontFamily="@font/dseg7_classic"
                    android:textColor="@color/seg_red" android:textSize="35px" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="12px" android:text="A" android:textColor="@color/txt_label"
                    android:textSize="23px" android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- ================= MIDDLE ROW ================= -->
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="0px" android:layout_weight="1"
            android:layout_marginTop="12px" android:orientation="horizontal">

            <!-- LEFT COLUMN -->
            <LinearLayout
                android:layout_width="900px" android:layout_height="match_parent" android:orientation="vertical">

                <!-- STATUS GRID -->
                <LinearLayout android:id="@+id/status_grid"
                    android:layout_width="match_parent" android:layout_height="206px"
                    android:orientation="horizontal" android:background="@drawable/bd_line14" android:padding="18px" />

                <!-- SCOPE -->
                <LinearLayout
                    android:layout_width="match_parent" android:layout_height="0px" android:layout_weight="1"
                    android:layout_marginTop="12px" android:orientation="vertical"
                    android:background="@drawable/bd_scope" android:padding="14px">

                    <!-- CKP / CMP1 / CMP2 plot -->
                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="0px" android:layout_weight="1.5"
                        android:orientation="horizontal" android:background="@drawable/bd_scope_plot"
                        android:paddingHorizontal="10px" android:paddingVertical="6px">
                        <LinearLayout android:layout_width="56px" android:layout_height="match_parent" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="0px" android:layout_weight="1"
                                android:gravity="center_vertical" android:text="CKP" android:textColor="#d8dde2" android:textSize="16px" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="0px" android:layout_weight="1"
                                android:gravity="center_vertical" android:text="CMP1" android:textColor="#d8dde2" android:textSize="16px" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="0px" android:layout_weight="1"
                                android:gravity="center_vertical" android:text="CMP2" android:textColor="#d8dde2" android:textSize="16px" android:textStyle="bold" />
                        </LinearLayout>
                        <com.alayed.ecutester.ui.ScopeView android:id="@+id/scope_view"
                            android:layout_width="0px" android:layout_height="match_parent" android:layout_weight="1"
                            android:layout_marginStart="10px" />
                    </LinearLayout>

                    <!-- CAN header -->
                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginTop="8px">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="CAN BUS" android:textColor="#e9edf1" android:textSize="18px" android:textStyle="bold" />
                        <View android:layout_width="0px" android:layout_height="1px" android:layout_weight="1" />
                        <View android:layout_width="9px" android:layout_height="9px" android:background="@drawable/bd_dot_green" />
                        <View android:layout_width="9px" android:layout_height="9px" android:layout_marginStart="10px" android:background="@drawable/bd_dot_green" />
                    </LinearLayout>

                    <!-- CAN plot (decorative, scrolling green square waves) -->
                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="0px" android:layout_weight="1"
                        android:layout_marginTop="8px" android:orientation="horizontal"
                        android:background="@drawable/bd_can_plot" android:paddingHorizontal="10px" android:paddingVertical="6px">
                        <LinearLayout android:layout_width="70px" android:layout_height="match_parent" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="0px" android:layout_weight="1"
                                android:gravity="center_vertical" android:maxLines="1" android:text="CAN HI" android:textColor="#d8dde2" android:textSize="16px" android:textStyle="bold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="0px" android:layout_weight="1"
                                android:gravity="center_vertical" android:maxLines="1" android:text="CAN LO" android:textColor="#d8dde2" android:textSize="16px" android:textStyle="bold" />
                        </LinearLayout>
                        <com.alayed.ecutester.ui.ScopeView android:id="@+id/can_scope"
                            android:layout_width="0px" android:layout_height="match_parent" android:layout_weight="1"
                            android:layout_marginStart="10px" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- GAUGES PANEL -->
            <LinearLayout
                android:layout_width="0px" android:layout_height="match_parent" android:layout_weight="1"
                android:layout_marginStart="14px" android:orientation="horizontal" android:weightSum="100"
                android:background="@drawable/bd_line14" android:padding="14px">

                <!-- left: indicators + RPM dial -->
                <LinearLayout
                    android:layout_width="0px" android:layout_height="match_parent" android:layout_weight="54"
                    android:orientation="vertical">
                    <LinearLayout android:id="@+id/indicators"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:background="@drawable/bd_indic"
                        android:paddingHorizontal="8px" android:paddingVertical="10px" />
                    <FrameLayout
                        android:layout_width="match_parent" android:layout_height="0px" android:layout_weight="1">
                        <com.alayed.ecutester.ui.RpmDialView android:id="@+id/rpm_dial"
                            android:layout_width="384px" android:layout_height="384px" android:layout_gravity="center" />
                    </FrameLayout>
                </LinearLayout>

                <!-- right: 6 mini gauges (filled in code) -->
                <LinearLayout android:id="@+id/mini_gauges"
                    android:layout_width="0px" android:layout_height="match_parent" android:layout_weight="46"
                    android:layout_marginStart="14px" android:orientation="vertical" />
            </LinearLayout>
        </LinearLayout>

        <!-- ================= BANKS (cells filled in code) =================
             Taller than the web (330→365) so each cell fits the component image
             plus a dedicated spark/spray zone beneath it; the flexible mid row
             above absorbs the difference. -->
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="365px"
            android:layout_marginTop="12px" android:orientation="horizontal">
            <LinearLayout android:id="@+id/bank_coil"
                android:layout_width="0px" android:layout_height="match_parent" android:layout_weight="1"
                android:background="@drawable/bd_coil" android:paddingHorizontal="14px" android:paddingTop="12px" android:paddingBottom="14px" />
            <LinearLayout android:id="@+id/bank_inj"
                android:layout_width="0px" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginStart="14px"
                android:background="@drawable/bd_inj" android:paddingHorizontal="14px" android:paddingTop="12px" android:paddingBottom="14px" />
            <LinearLayout android:id="@+id/bank_gdi"
                android:layout_width="0px" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginStart="14px"
                android:background="@drawable/bd_gdi" android:paddingHorizontal="14px" android:paddingTop="12px" android:paddingBottom="14px" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
